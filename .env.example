# Stripe (test mode for M1)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Neon Postgres (free tier; from Vercel Storage or Neon console)
# Pooled URL for API runtime (Vercel sets DATABASE_URL when Neon is linked)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct URL for migrations (optional; Vercel Neon integration may set DATABASE_URL_UNPOOLED)
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# API
ADMIN_API_KEY=change-me-in-production
PORT=3000
NODE_ENV=development

# M2
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# CORS_ORIGIN=https://your-app.vercel.app

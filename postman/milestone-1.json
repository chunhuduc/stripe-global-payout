{
  "info": {
    "name": "Stripe Connect Payout API - Phase 1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://your-project.vercel.app" },
    { "key": "adminKey", "value": "change-me-in-production" },
    { "key": "payeeId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Create payee (Jordan)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Admin-Key", "value": "{{adminKey}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"countryCode\": \"JO\",\n  \"individual\": {\n    \"firstName\": \"Test\",\n    \"lastName\": \"Recipient\",\n    \"email\": \"test.recipient@example.com\"\n  },\n  \"bank\": {\n    \"accountHolderName\": \"Test Recipient\",\n    \"iban\": \"JO32ABCJ0010123456789012345678\",\n    \"swift\": \"AAAajoJOXXX\"\n  }\n}"
        },
        "url": "{{baseUrl}}/api/payees"
      }
    },
    {
      "name": "Initiate payout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Admin-Key", "value": "{{adminKey}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payeeId\": \"{{payeeId}}\",\n  \"amount\": 1000,\n  \"currency\": \"jod\",\n  \"transferCurrency\": \"usd\"\n}"
        },
        "url": "{{baseUrl}}/api/payouts"
      }
    }
  ]
}

{
  "info": {
    "name": "Stripe Payout Mini-Flow (trial demo)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Three requests for Aaron trial: save freelancer, trigger payout, check status. Set payeeId and payoutId from prior responses."
  },
  "variable": [
    { "key": "baseUrl", "value": "https://aaron-stripe-payout-api.vercel.app" },
    { "key": "adminKey", "value": "change-me-in-production" },
    { "key": "payeeId", "value": "" },
    { "key": "payoutId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Save freelancer + bank",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Admin-Key", "value": "{{adminKey}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.test\",\n  \"bank\": {\n    \"iban\": \"JO32ABCJ0010123456789012345678\",\n    \"swift\": \"AAAajoJOXXX\"\n  }\n}"
        },
        "url": "{{baseUrl}}/api/payees"
      }
    },
    {
      "name": "2. Trigger payout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Admin-Key", "value": "{{adminKey}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payeeId\": \"{{payeeId}}\",\n  \"amount\": 1000,\n  \"currency\": \"jod\",\n  \"transferCurrency\": \"usd\"\n}"
        },
        "url": "{{baseUrl}}/api/payouts"
      }
    },
    {
      "name": "3. Get payout status",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-Admin-Key", "value": "{{adminKey}}" }
        ],
        "url": "{{baseUrl}}/api/payouts/{{payoutId}}"
      }
    }
  ]
}

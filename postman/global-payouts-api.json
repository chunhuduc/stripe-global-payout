{
  "info": {
    "name": "stripe-global-payout",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Global Payouts API: Jordan recipient + payout method, optional outbound payment, status. Requires GP sandbox. See docs/TESTING.md."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "adminKey", "value": "change-me-in-production" },
    { "key": "payeeId", "value": "" },
    { "key": "payoutId", "value": "" }
  ],
  "item": [
    {
      "name": "0. Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "1. Save recipient + bank (Jordan)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Admin-Key", "value": "{{adminKey}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.test\",\n  \"countryCode\": \"JO\",\n  \"bank\": {\n    \"iban\": \"JO32ABCJ0010123456789012345678\",\n    \"swift\": \"AAAAJOJOXXX\",\n    \"accountHolderName\": \"Jane Doe\"\n  }\n}"
        },
        "url": "{{baseUrl}}/api/payees"
      }
    },
    {
      "name": "2. (Optional) Outbound payment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Admin-Key", "value": "{{adminKey}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"payeeId\": \"{{payeeId}}\",\n  \"amount\": 1000,\n  \"currency\": \"jod\"\n}"
        },
        "url": "{{baseUrl}}/api/payouts"
      }
    },
    {
      "name": "3. (Optional) Get payout status",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-Admin-Key", "value": "{{adminKey}}" }
        ],
        "url": "{{baseUrl}}/api/payouts/{{payoutId}}"
      }
    }
  ]
}
